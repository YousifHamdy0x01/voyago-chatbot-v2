# ── Voyago Chatbot – Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# Voyago Backend API
VOYAGO_API_BASE=http://voyagoo.runasp.net
HOTELS_ENDPOINT=/hotels
ATTRACTIONS_ENDPOINT=/Attractions
RESTAURANTS_ENDPOINT=/Restaurants
TOURGUIDES_ENDPOINT=/TourGuides

# CORS – comma-separated allowed origins (use * for development only)
ALLOWED_ORIGINS=["*"]

# Context memory: how many past turns to remember per session
CONTEXT_MAX_TURNS=5

# Dataset path (relative to project root)
DATASET_PATH=data/voyago_dataset.csv
